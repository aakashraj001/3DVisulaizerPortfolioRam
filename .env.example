# Copy to `.env` and fill in. All are OPTIONAL — the site runs with no .env at all.

# Image CDN base URL. Renders are served through this with auto WebP/AVIF + resize.
# ImageKit:   https://ik.imagekit.io/your_id
# Cloudinary: https://res.cloudinary.com/your_cloud/image/fetch
# Leave UNSET for passthrough (placeholder/remote images load as-is).
VITE_IMAGE_CDN_BASE=

# Content source for the gallery + hero. Default 'placeholder' reads data/projects.json.
# placeholder | sanity | decap
VITE_CMS_SOURCE=placeholder

# Only when VITE_CMS_SOURCE=sanity
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
