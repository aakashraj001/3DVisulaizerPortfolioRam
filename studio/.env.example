# Copy to `.env` and fill in. All optional — the app runs with no .env.

# Image CDN base (ImageKit/Cloudinary). Unset = passthrough (Unsplash URLs used as-is).
# ImageKit: https://ik.imagekit.io/your_id
VITE_IMAGE_CDN_BASE=

# Content source for work + services. Default 'placeholder' reads data/*.json.
# placeholder | sanity | decap
VITE_CMS_SOURCE=placeholder

# Only when VITE_CMS_SOURCE=sanity
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
